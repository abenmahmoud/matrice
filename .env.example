# ============================================================
# Matrice Narrative — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# --- Base de données PostgreSQL ---
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgres://matrice:changeme_strong_password_here@postgres:5432/matrice_narrative

# --- Sécurité session ---
SESSION_SECRET=changeme_generate_with_openssl_rand_hex_64
CRON_SECRET=changeme_generate_with_openssl_rand_hex_32

# --- OpenAI (via Replit AI Integrations proxy, ou votre propre clé) ---
# Option A : Replit AI Integrations (auto-provisioned, pas besoin de clé perso)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://...replit.ai/openai/v1
AI_INTEGRATIONS_OPENAI_API_KEY=dummy_key_for_sdk_compat
AI_MODEL=gpt-4o
# Modele par plan (Phase 2A Ticket 8)
AI_MODEL_FREE=gpt-4o-mini
AI_MODEL_PRO=gpt-4o
AI_MODEL_STUDIO=gpt-4o
AI_MODEL_ENTERPRISE=gpt-4o
AI_MODEL_OVERRIDE_OWNER=gpt-4o

# Option B : Votre propre clé OpenAI (commentez l'option A et utilisez ceci)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...votre-clé...
# AI_MODEL=gpt-4o

# --- DeepSeek (Lentille Marche 2026) ---
# API compatible OpenAI, utilisee pour reduire le cout des analyses production.
DEEPSEEK_API_KEY=sk-...votre-cle-deepseek...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LENTILLE_DEEPSEEK_MAX_TOKENS=4000
LENTILLE_DEEPSEEK_TEMPERATURE=0.7

# --- Serveur ---
NODE_ENV=production
PORT=8080

# --- Acces produit ---
# commercial = SaaS/public: comptes requis, quotas et modules avances reserves.
# private = instance personnelle explicite, tout est ouvert au proprietaire.
MATRICE_PRODUCT_MODE=commercial
MATRICE_DEFAULT_PLAN=free
MATRICE_FREE_PROJECT_LIMIT=1
MATRICE_FREE_PROGRESSION_CAP=35
MATRICE_FREE_GENERATION_LIMIT=2

# --- Identite / acces ---
# local = comptes email/mot de passe signes par SESSION_SECRET.
# admin-token = le token admin continue d'identifier le proprietaire.
# clerk = future integration possible comptes utilisateurs / abonnements.
MATRICE_AUTH_PROVIDER=local

# --- Emails transactionnels ---
EMAIL_PROVIDER=brevo
BREVO_API_KEY=xkeysib_REPLACE_ME
# Fallback possible si vous gardez Resend sur un autre domaine verifie.
RESEND_API_KEY=re_...
MATRICE_PUBLIC_BASE_URL=https://matrice.essuf.fr
MATRICE_BASE_URL=https://matrice.essuf.fr
MATRICE_EMAIL_FROM=Matrice <no-reply@matrice.essuf.fr>
MATRICE_FROM_EMAIL=no-reply@matrice.essuf.fr
MATRICE_FROM_NAME=Matrice

# --- Paiements Stripe ---
STRIPE_SECRET_KEY=sk_live_or_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_STUDIO=price_REPLACE_ME
STRIPE_PRICE_PUBLISH=price_REPLACE_ME

# --- Preuve OpenTimestamps ---
# Calendriers publics separes par des virgules. Par defaut: a/b.pool.opentimestamps.org
OTS_CALENDARS=
OTS_ESPLORA_URL=https://blockstream.info/api
OTS_ESPLORA_TIMEOUT_MS=5000

# --- Ports hôte Docker (VPS) ---
# Par défaut, Matrice écoute seulement en local. Le Nginx système du VPS
# doit ensuite proxy vers FRONTEND_HOST_PORT.
API_HOST_BIND=127.0.0.1
API_HOST_PORT=8090
FRONTEND_HOST_BIND=127.0.0.1
FRONTEND_HOST_PORT=8091
