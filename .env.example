# ============================================================
# Matrice Narrative — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# --- Base de données PostgreSQL ---
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgres://matrice:changeme_strong_password_here@postgres:5432/matrice_narrative

# --- Sécurité session ---
SESSION_SECRET=changeme_generate_with_openssl_rand_hex_64

# --- OpenAI (via Replit AI Integrations proxy, ou votre propre clé) ---
# Option A : Replit AI Integrations (auto-provisioned, pas besoin de clé perso)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://...replit.ai/openai/v1
AI_INTEGRATIONS_OPENAI_API_KEY=dummy_key_for_sdk_compat
AI_MODEL=gpt-4o

# Option B : Votre propre clé OpenAI (commentez l'option A et utilisez ceci)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...votre-clé...
# AI_MODEL=gpt-4o

# --- Serveur ---
NODE_ENV=production
PORT=8080

# --- Acces produit ---
# private = instance personnelle, tout est ouvert.
# commercial = futur SaaS: parcours gratuit limite, modules avances reserves.
MATRICE_PRODUCT_MODE=private
MATRICE_DEFAULT_PLAN=free
MATRICE_FREE_PROJECT_LIMIT=1
MATRICE_FREE_PROGRESSION_CAP=35

# --- Identite / acces ---
# admin-token = separation actuelle: le token admin identifie le proprietaire.
# clerk = future integration comptes utilisateurs / abonnements.
MATRICE_AUTH_PROVIDER=admin-token

# --- Ports hôte Docker (VPS) ---
# Par défaut, Matrice écoute seulement en local. Le Nginx système du VPS
# doit ensuite proxy vers FRONTEND_HOST_PORT.
API_HOST_BIND=127.0.0.1
API_HOST_PORT=8090
FRONTEND_HOST_BIND=127.0.0.1
FRONTEND_HOST_PORT=8091
