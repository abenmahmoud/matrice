# System Nginx reverse proxy for Matrice on the VPS.
#
# Usage:
# 1. Replace `matrice.example.com` with the chosen private subdomain.
# 2. Copy to `/etc/nginx/sites-available/matrice`.
# 3. Enable with `ln -s /etc/nginx/sites-available/matrice /etc/nginx/sites-enabled/matrice`.
# 4. Validate with `nginx -t`.
# 5. Reload with `systemctl reload nginx`.
# 6. Add TLS with `certbot --nginx -d matrice.example.com`.

server {
    listen 80;
    server_name matrice.example.com;

    client_max_body_size 25m;

    location /api/ {
        proxy_pass http://127.0.0.1:8090/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 180s;
        proxy_send_timeout 180s;
    }

    location / {
        proxy_pass http://127.0.0.1:8091;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 180s;
        proxy_send_timeout 180s;
    }
}
