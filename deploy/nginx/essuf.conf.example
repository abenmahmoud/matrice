# System Nginx reverse proxy for the Essuf-Group company portal.
#
# Current audit notes (2026-05-31):
# - matrice.essuf.fr and sign.essuf.fr already point to the VPS.
# - essuf.fr and www.essuf.fr may still point to OVH hosting/parking.
#
# Usage on the VPS:
# 1. Start the static portal service:
#      docker compose build essuf-portal
#      docker compose up -d essuf-portal
# 2. Copy this file to `/etc/nginx/sites-available/essuf`.
# 3. Enable with `ln -s /etc/nginx/sites-available/essuf /etc/nginx/sites-enabled/essuf`.
# 4. Validate with `nginx -t`.
# 5. Reload with `systemctl reload nginx`.
# 6. Add TLS with `certbot --nginx -d essuf.fr -d www.essuf.fr`.
# 7. Point DNS A records `essuf.fr` and `www.essuf.fr` to the VPS IP.

server {
    listen 80;
    server_name essuf.fr www.essuf.fr;

    location / {
        proxy_pass http://127.0.0.1:8092;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
